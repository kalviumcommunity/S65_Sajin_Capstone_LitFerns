# Production Environment Variables Template
# Copy to .env.production and fill in your actual values

# API Server URL (your production backend domain)
# Example for Render: https://litferns-api.onrender.com
# Example for Vercel: https://litferns-api.vercel.app
VITE_API_URL=https://your-production-api-url.com

# Upload API URL - Same as API_URL (uploads are handled by main server)
# In production, the upload routes are at /api/uploadthing on the main server
VITE_UPLOAD_API_URL=https://your-production-api-url.com
