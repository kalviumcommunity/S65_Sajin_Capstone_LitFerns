# Client Development Environment
# The Vite dev server runs on localhost:5173
# API requests go to localhost:5000 (main Express server)

# Main API Server URL
VITE_API_URL=http://localhost:5000

# Upload API URL (same server, different route)
# The main server handles uploads at /api/uploadthing
VITE_UPLOAD_API_URL=http://localhost:5000
