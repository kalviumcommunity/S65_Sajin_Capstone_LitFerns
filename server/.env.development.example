# MongoDB Development Connection
# For local development, use: mongodb://localhost:27017/litferns
# For MongoDB Atlas, use your connection string: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGO_URI=mongodb://localhost:27017/litferns

# Node Environment (keep as 'development' for dev)
NODE_ENV=development

# Server Port (main API server handles both API and uploads)
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# JWT Secret - CHANGE THIS! Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_generated_secret_key_here

# UploadThing API Token - Get from https://uploadthing.com/dashboard
# This is an API key and should be kept secret
UPLOADTHING_TOKEN=sk_live_your_uploadthing_token_here
