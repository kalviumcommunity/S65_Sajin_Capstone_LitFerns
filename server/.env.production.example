# Server Production Environment Template
# Copy to .env.production and fill in your actual values

# MongoDB Atlas Connection (use the service provider's connection string)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/litferns

# Node Environment
NODE_ENV=production

# Server Port (Render, Vercel will set this via PORT environment variable)
PORT=5000

# Frontend URL (where your React app is deployed)
# Example for Vercel: https://litferns.vercel.app
FRONTEND_URL=https://your-production-frontend-url.com

# JWT Secret (MUST be different from development!)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_long_random_secret_key_change_this_immediately

# UploadThing API Token (regenerated and security-rotated)
# Get from: https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=sk_live_your_regenerated_token_here
